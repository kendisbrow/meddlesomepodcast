---
layout: null
permalink: /search.json
---

[
  {% assign docs = site.posts | concat: site.transcripts %}
  {% for doc in docs %}
    {
      "title": {{ doc.title | jsonify }},
      "url": "{{ doc.url | relative_url }}",
      "content": {{ doc.content | strip_html | replace: "\t", " " | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]

